# Local development
DATABASE_URL=postgres://user@localhost/cr_dev

# In dev: images load from production. In production: leave empty (served via Cloudflare Worker).
IMAGE_BASE_URL=https://ceskarepublika.wiki

# --- Streamtape (video library hosting) ---
# Account: tuma.rsrobot@gmail.com. Get credentials from https://streamtape.com/accpanel.
STREAMTAPE_LOGIN=
STREAMTAPE_KEY=

# --- Cloudflare R2 (also used for video thumbnails — same bucket as images) ---
# R2_BUCKET should match the existing image bucket (cr-images).
# R2_PUBLIC_BASE_URL is the CDN host that fronts the bucket (typically ceskarepublika.wiki via Worker).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cr-images
R2_PUBLIC_BASE_URL=https://ceskarepublika.wiki
